    "imapflow": "^1.0.162",
    "ioredis": "^5.3.2",
    "isbot": "^5.1.0",
    "nodemailer": "^6.9.9",
    "pino": "^9.5.0",
    "playwright": "^1.49.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
