# Shopify (Dev Dashboard app - post Jan 2026)
# Get SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET from the Dev Dashboard app credentials page.
# Access token is fetched automatically via client credentials grant — leave SHOPIFY_ACCESS_TOKEN blank.
# Scopes are configured in the Dev Dashboard UI, not here.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
# Leave blank - token is fetched automatically
SHOPIFY_ACCESS_TOKEN=

# Database
# Production: postgresql://user:password@host:5432/dbname
# Development: file:./dev.db (SQLite — set in prisma/schema.prisma directly)
DATABASE_URL=file:./dev.db

# Redis
REDIS_URL=redis://localhost:6380

# Anthropic
ANTHROPIC_API_KEY=

# Google OAuth (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app-url.trycloudflare.com/settings/email/google/callback

# Microsoft OAuth (Outlook)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-app-url.trycloudflare.com/settings/email/microsoft/callback
MICROSOFT_TENANT_ID=common

# Error Monitoring
SENTRY_DSN=

# Email Tracking
TRACKING_BASE_URL=https://your-app-url.trycloudflare.com

# App Config
NODE_ENV=development
LOG_LEVEL=info

# Token Encryption (32 random bytes, hex-encoded)
ENCRYPTION_KEY=
